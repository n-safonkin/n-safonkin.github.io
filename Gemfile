source "https://rubygems.org"

# Jekyll 4.x for local preview (compatible with modern Ruby).
# GitHub Pages itself still builds with Jekyll 3.9, but for a static site
# with no plugins, the rendered output is the same.
gem "jekyll", "~> 4.3"
gem "kramdown-parser-gfm"

# webrick was removed from the Ruby stdlib in Ruby 3.0+ but Jekyll's
# serve command still uses it.
gem "webrick"
